@mcp.tool()
def list_asset_group_assets(asset_group_id: str, customer_id: str = "") -> str:
    """Listet alle Assets einer PMax-Asset-Gruppe nach field_type mit Anzahl + Approval-Status.
    Zum Pruefen, was fehlt (z.B. LOGO, BUSINESS_NAME) oder disapproved ist.
    """
    client = get_client()
    cid = customer_id or DEFAULT_CUSTOMER_ID
    ga = client.get_service("GoogleAdsService")
    q = ("SELECT asset_group_asset.field_type, asset_group_asset.status, "
         "asset_group_asset.policy_summary.approval_status, asset.id, asset.type "
         f"FROM asset_group_asset WHERE asset_group.id={asset_group_id}")
    counts = {}
    for b in ga.search_stream(customer_id=cid, query=q):
        for r in b.results:
            ft = r.asset_group_asset.field_type.name
            ap = r.asset_group_asset.policy_summary.approval_status.name
            d = counts.setdefault(ft, {})
            d[ap] = d.get(ap, 0) + 1
    return json.dumps({"asset_group_id": asset_group_id, "by_field_type": counts}, ensure_ascii=False)


@mcp.tool()
def remove_asset_group_asset(asset_group_id: str, asset_id: str, field_type: str = "HEADLINE", customer_id: str = "") -> str:
    """Entfernt (loescht) die Verknuepfung eines Assets von einer PMax-Asset-Gruppe (AssetGroupAsset remove).
    asset_id aus run_gaql_report (asset.id), field_type = HEADLINE/LONG_HEADLINE/DESCRIPTION/
    BUSINESS_NAME/MARKETING_IMAGE/SQUARE_MARKETING_IMAGE/PORTRAIT_MARKETING_IMAGE/LOGO etc.
    Das Asset selbst bleibt in der Bibliothek; nur die Bindung an die Gruppe wird geloescht.
    Nutzen: disapproved/limitierte Texte aus einer aktiven Gruppe rausnehmen.
    """
    client = get_client()
    cid = customer_id or DEFAULT_CUSTOMER_ID
    svc = client.get_service("AssetGroupAssetService")
    op = client.get_type("AssetGroupAssetOperation")
    op.remove = f"customers/{cid}/assetGroupAssets/{asset_group_id}~{asset_id}~{field_type}"
    req = client.get_type("MutateAssetGroupAssetsRequest")
    req.customer_id = cid
    req.operations.append(op)
    req.validate_only = DRY_RUN
    resp = svc.mutate_asset_group_assets(request=req)
    removed = resp.results[0].resource_name if resp.results else None
    return json.dumps({"dry_run": DRY_RUN, "removed": removed, "asset_group_id": asset_group_id, "asset_id": asset_id, "field_type": field_type})


@mcp.tool()
def update_asset_group_final_url(asset_group_id: str, final_url: str, final_mobile_url: str = "", customer_id: str = "") -> str:
    """Aendert die Final-URL(s) einer PMax-Asset-Gruppe (asset_group.final_urls).
    Damit eine Gruppe auf die richtige Landingpage zeigt (z.B. Jawline -> /hyaluron/jawline
    statt Uebersicht /hyaluron). final_url = Pflicht-Ziel-URL; final_mobile_url optional.
    asset_group_id per run_gaql_report finden
    ("SELECT asset_group.id, asset_group.name, asset_group.final_urls FROM asset_group WHERE campaign.id=...").
    """
    client = get_client()
    cid = customer_id or DEFAULT_CUSTOMER_ID
    svc = client.get_service("AssetGroupService")
    op = client.get_type("AssetGroupOperation")
    ag = op.update
    ag.resource_name = svc.asset_group_path(cid, asset_group_id)
    ag.final_urls.append(final_url)
    if final_mobile_url:
        ag.final_mobile_urls.append(final_mobile_url)
    client.copy_from(op.update_mask, protobuf_helpers.field_mask(None, ag._pb))
    req = client.get_type("MutateAssetGroupsRequest")
    req.customer_id = cid
    req.operations.append(op)
    req.validate_only = DRY_RUN
    resp = svc.mutate_asset_groups(request=req)
    return json.dumps({"dry_run": DRY_RUN, "resource_name": resp.results[0].resource_name if resp.results else None, "final_url": final_url, "final_mobile_url": final_mobile_url or None})


# --- HTTP-App mit Bearer-Auth ---
class BearerAuthMiddleware(BaseHTTPMiddleware):
    async def dispatch(self, request, call_next):
        # /healthz ohne Auth (für Monitoring)
        if request.url.path.rstrip("/").endswith("healthz"):
            return await call_next(request)
        token = os.environ.get("CONNECTOR_TOKEN")
        if token:
            # Akzeptiere Token via Header (Authorization: Bearer ...) ODER via
            # Query-Param (?token=...), weil Claudes Connector-Dialog kein
            # Header-Feld bietet.
            header_ok = request.headers.get("authorization", "") == f"Bearer {token}"
            query_ok = request.query_params.get("token", "") == token
            if not (header_ok or query_ok):
                return JSONResponse({"error": "unauthorized"}, status_code=401)
        return await call_next(request)


