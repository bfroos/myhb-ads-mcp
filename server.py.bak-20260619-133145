# --- Erstell-Tools: Budget, Kampagne, Anzeigengruppe, Status ---
# Flow Search-Stadt: create_campaign_budget -> create_search_campaign
# -> create_ad_group (je Thema) -> add_keywords + create_responsive_search_ad
# -> set_campaign_status ENABLED nach Verifikation.

@mcp.tool()
def create_campaign_budget(name: str, amount_eur: float, customer_id: str = "") -> str:
    """Legt ein (nicht geteiltes) Tagesbudget an und gibt budget_id zurueck.
    amount_eur = Tagesbudget in EUR. Danach mit create_search_campaign verwenden.
    """
    client = get_client()
    cid = customer_id or DEFAULT_CUSTOMER_ID
    svc = client.get_service("CampaignBudgetService")
    op = client.get_type("CampaignBudgetOperation")
    b = op.create
    b.name = name
    b.amount_micros = int(round(amount_eur * 1_000_000))
    b.delivery_method = client.enums.BudgetDeliveryMethodEnum.STANDARD
    b.explicitly_shared = False
    req = client.get_type("MutateCampaignBudgetsRequest")
    req.customer_id = cid
    req.operations.append(op)
    req.validate_only = DRY_RUN
    resp = svc.mutate_campaign_budgets(request=req)
    rn = resp.results[0].resource_name if resp.results else None
    bid = rn.split("/")[-1] if rn else None
    return json.dumps({"dry_run": DRY_RUN, "budget_id": bid, "resource_name": rn})


@mcp.tool()
def create_search_campaign(
    name: str,
    budget_id: str,
    geo_target_ids: list[str],
    language_ids: list[str] = ["1000", "1001"],
    status: str = "PAUSED",
    customer_id: str = "",
) -> str:
    """Legt eine Such-Kampagne an (Gebotsstrategie MAXIMIZE_CONVERSIONS, Display AUS,
    Suchnetz AN) inkl. Geo- und Sprach-Targeting. Wird per Default PAUSED angelegt
    (erst nach Verifikation per set_campaign_status scharf schalten).
    geo_target_ids: Liste von GeoTargetConstant-IDs (z.B. ['1004576'] = Aachen Stadt).
    language_ids: Default DE(1000)+EN(1001). status: PAUSED oder ENABLED.
    Brand-Ausschluss laeuft konto-weit automatisch (account-level negatives).
    Gibt campaign_id zurueck.
    """
    client = get_client()
    cid = customer_id or DEFAULT_CUSTOMER_ID
    csvc = client.get_service("CampaignService")
    bsvc = client.get_service("CampaignBudgetService")
    op = client.get_type("CampaignOperation")
    camp = op.create
    camp.name = name
    camp.advertising_channel_type = client.enums.AdvertisingChannelTypeEnum.SEARCH
    camp.status = client.enums.CampaignStatusEnum[status]
    camp.campaign_budget = bsvc.campaign_budget_path(cid, budget_id)
    camp.maximize_conversions = client.get_type("MaximizeConversions")
    camp.bidding_strategy_type = client.enums.BiddingStrategyTypeEnum.MAXIMIZE_CONVERSIONS
    ns = camp.network_settings
    ns.target_google_search = True
    ns.target_search_network = True
    ns.target_content_network = False
    ns.target_partner_search_network = False
    camp.geo_target_type_setting.positive_geo_target_type = client.enums.PositiveGeoTargetTypeEnum.PRESENCE_OR_INTEREST
    camp.geo_target_type_setting.negative_geo_target_type = client.enums.NegativeGeoTargetTypeEnum.PRESENCE
    camp.contains_eu_political_advertising = client.enums.EuPoliticalAdvertisingStatusEnum.DOES_NOT_CONTAIN_EU_POLITICAL_ADVERTISING
    req = client.get_type("MutateCampaignsRequest")
    req.customer_id = cid
    req.operations.append(op)
    req.validate_only = DRY_RUN
    resp = csvc.mutate_campaigns(request=req)
    rn = resp.results[0].resource_name if resp.results else None
    camp_id = rn.split("/")[-1] if rn else None
    # Geo + Sprache als CampaignCriterion ergaenzen
    if rn and not DRY_RUN:
        cc_svc = client.get_service("CampaignCriterionService")
        geo_svc = client.get_service("GeoTargetConstantService")
        ops = []
        for gid in geo_target_ids:
            o = client.get_type("CampaignCriterionOperation")
            o.create.campaign = rn
            o.create.location.geo_target_constant = geo_svc.geo_target_constant_path(gid)
            ops.append(o)
        for lg in language_ids:
            o = client.get_type("CampaignCriterionOperation")
            o.create.campaign = rn
            o.create.language.language_constant = f"languageConstants/{lg}"
            ops.append(o)
        creq = client.get_type("MutateCampaignCriteriaRequest")
        creq.customer_id = cid
        creq.operations.extend(ops)
        cc_svc.mutate_campaign_criteria(request=creq)
    return json.dumps({"dry_run": DRY_RUN, "campaign_id": camp_id, "resource_name": rn,
                       "geo": geo_target_ids, "languages": language_ids, "status": status})


