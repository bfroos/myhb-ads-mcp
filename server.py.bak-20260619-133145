# --- Bild-Asset-Tools ---
# AD_IMAGE = korrekter Feldtyp fuer Bilderweiterungen bei SUCH-Kampagnen
# (MARKETING_IMAGE etc. sind dort inkompatibel). Verifiziert 2026-06-17.

@mcp.tool()
def list_image_assets(name_contains: str = "", min_width: int = 0, min_height: int = 0, limit: int = 50, customer_id: str = "") -> str:
    """Listet Bild-Assets aus der Asset-Bibliothek (zum Wiederverwenden per add_image_extension).
    Optional filtern nach Namens-Teilstring und Mindestgroesse. Gibt id, name, width, height zurueck.
    """
    client = get_client()
    cid = customer_id or DEFAULT_CUSTOMER_ID
    ga = client.get_service("GoogleAdsService")
    q = ("SELECT asset.id, asset.name, asset.image_asset.full_size.width_pixels, "
         "asset.image_asset.full_size.height_pixels FROM asset WHERE asset.type = 'IMAGE'")
    out = []
    for b in ga.search_stream(customer_id=cid, query=q):
        for r in b.results:
            w = r.asset.image_asset.full_size.width_pixels
            h = r.asset.image_asset.full_size.height_pixels
            nm = r.asset.name or ""
            if name_contains and name_contains.lower() not in nm.lower():
                continue
            if w < min_width or h < min_height:
                continue
            out.append({"id": str(r.asset.id), "name": nm, "w": w, "h": h})
            if len(out) >= limit:
                break
        if len(out) >= limit:
            break
    return json.dumps({"count": len(out), "assets": out}, ensure_ascii=False)


