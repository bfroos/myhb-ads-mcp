"""
Google Ads MCP-Server für My Health & Beauty.
Stellt lese- und schreibfähige Google-Ads-Tools über MCP (Streamable HTTP) bereit.
Läuft auf bfr.roos.rocks hinter Caddy (Pfad /ads-mcp/). Secrets aus Umgebungsvariablen.

Tools:
 - run_gaql_report (lesen: beliebige GAQL-Reports)
 - create_responsive_search_ad
 - update_ad_status (ENABLED/PAUSED)
 - add_negative_keywords (Anzeigengruppen-Ebene)
 - add_keywords (positive Keywords, Anzeigengruppen-Ebene)
 - set_keyword_status (bestehendes Keyword ENABLED/PAUSED, z.B. Niedrig-QS pausieren)
 - create_campaign_budget / create_search_campaign / create_ad_group (Neuaufbau Such-Stadt)
 - set_campaign_status / set_asset_group_status (Scharfschalten/Pausieren, PMax-Bereinigung)
 - update_campaign_budget (Tagesbudget in EUR)

Sicherheit:
 - Bearer-Token-Schutz (CONNECTOR_TOKEN) auf dem HTTP-Endpoint.
 - DRY_RUN=1 -> alle Schreib-Operationen laufen als validate_only (keine echten Änderungen).
"""

import os
import json
from functools import lru_cache

from google.protobuf.json_format import MessageToDict
from google.api_core import protobuf_helpers
from google.ads.googleads.client import GoogleAdsClient

from mcp.server.fastmcp import FastMCP
from mcp.server.transport_security import TransportSecuritySettings
from starlette.middleware.base import BaseHTTPMiddleware
from starlette.responses import JSONResponse, PlainTextResponse
from starlette.routing import Route
import uvicorn

DEFAULT_CUSTOMER_ID = os.environ.get("GOOGLE_ADS_CUSTOMER_ID", "7904003244")  # My Health & Beauty
DRY_RUN = os.environ.get("DRY_RUN", "0") == "1"


@lru_cache(maxsize=1)
def get_client() -> GoogleAdsClient:
    cfg = {
        "developer_token": os.environ["GOOGLE_ADS_DEVELOPER_TOKEN"],
        "client_id": os.environ["GOOGLE_ADS_CLIENT_ID"],
        "client_secret": os.environ["GOOGLE_ADS_CLIENT_SECRET"],
        "refresh_token": os.environ["GOOGLE_ADS_REFRESH_TOKEN"],
        "use_proto_plus": True,
    }
    # login_customer_id nur setzen, wenn vorhanden (für 7904003244 = self/leer).
    login = os.environ.get("GOOGLE_ADS_LOGIN_CUSTOMER_ID", "").strip()
    if login:
        cfg["login_customer_id"] = login
    return GoogleAdsClient.load_from_dict(cfg)


# Hinter Caddy laeuft der echte Host als bfr.roos.rocks durch; in der allowed-Liste
# zulassen, sonst blockt der DNS-Rebinding-Schutz mit 421 "Invalid Host header".
_sec = TransportSecuritySettings(
    allowed_hosts=["bfr.roos.rocks", "127.0.0.1", "127.0.0.1:8090", "localhost"],
    allowed_origins=["https://bfr.roos.rocks"],
)
mcp = FastMCP("google-ads", transport_security=_sec)


@mcp.tool()
def run_gaql_report(query: str, customer_id: str = "", limit: int = 200) -> str:
    """Führt eine GAQL-Abfrage aus und gibt die Zeilen als JSON zurück.
    Beispiel: "SELECT campaign.name, metrics.cost_micros, metrics.conversions FROM campaign WHERE segments.date DURING LAST_30_DAYS".
    """
    client = get_client()
    cid = customer_id or DEFAULT_CUSTOMER_ID
    ga = client.get_service("GoogleAdsService")
    rows = []
    done = False
    for batch in ga.search_stream(customer_id=cid, query=query):
        for row in batch.results:
            rows.append(MessageToDict(row._pb))
            if len(rows) >= limit:
                done = True
                break
        if done:
            break
    return json.dumps({"customer_id": cid, "row_count": len(rows), "rows": rows}, ensure_ascii=False)


def _text_asset(client, text: str):
    asset = client.get_type("AdTextAsset")
    asset.text = text
    return asset


@mcp.tool()
def create_responsive_search_ad(
    ad_group_id: str,
    final_url: str,
    headlines: list[str],
    descriptions: list[str],
    path1: str = "",
    path2: str = "",
    status: str = "ENABLED",
    customer_id: str = "",
) -> str:
    """Legt eine neue responsive Suchanzeige (RSA) in einer bestehenden Anzeigengruppe an.
    headlines: 3-15 Anzeigentitel (je <=30 Zeichen). descriptions: 2-4 Textzeilen (je <=90 Zeichen).
    Wichtig: final_url muss auf go.myhealthandbeauty.com zeigen (Botox-frei), niemals .app.
    """
    client = get_client()
    cid = customer_id or DEFAULT_CUSTOMER_ID
    svc = client.get_service("AdGroupAdService")
    ag_svc = client.get_service("AdGroupService")

    op = client.get_type("AdGroupAdOperation")
    aga = op.create
    aga.ad_group = ag_svc.ad_group_path(cid, ad_group_id)
    aga.status = client.enums.AdGroupAdStatusEnum[status]
    ad = aga.ad
    ad.final_urls.append(final_url)
    rsa = ad.responsive_search_ad
    if path1:
        rsa.path1 = path1
    if path2:
        rsa.path2 = path2
    rsa.headlines.extend([_text_asset(client, h) for h in headlines])
    rsa.descriptions.extend([_text_asset(client, d) for d in descriptions])

    request = client.get_type("MutateAdGroupAdsRequest")
    request.customer_id = cid
    request.operations.append(op)
    request.validate_only = DRY_RUN
    resp = svc.mutate_ad_group_ads(request=request)
    rn = resp.results[0].resource_name if resp.results else None
    return json.dumps({"dry_run": DRY_RUN, "resource_name": rn, "headlines": len(headlines), "descriptions": len(descriptions)})


