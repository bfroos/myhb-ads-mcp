# --- Asset-Tools (Sitelinks, Callouts, Structured Snippets) ---
# Flow: Asset(s) anlegen -> resource_name(s) -> an Kampagne binden (CampaignAsset).

def _create_assets(client, cid: str, ops: list):
    """Legt Assets an und gibt deren resource_names zurueck (respektiert DRY_RUN)."""
    svc = client.get_service("AssetService")
    req = client.get_type("MutateAssetsRequest")
    req.customer_id = cid
    req.operations.extend(ops)
    req.validate_only = DRY_RUN
    resp = svc.mutate_assets(request=req)
    return [r.resource_name for r in resp.results]


def _link_assets_to_campaign(client, cid: str, campaign_id: str, asset_resource_names: list, field_type: str):
    """Bindet Assets per CampaignAsset an eine Kampagne (respektiert DRY_RUN)."""
    camp_svc = client.get_service("CampaignService")
    ca_svc = client.get_service("CampaignAssetService")
    req = client.get_type("MutateCampaignAssetsRequest")
    req.customer_id = cid
    for rn in asset_resource_names:
        op = client.get_type("CampaignAssetOperation")
        op.create.campaign = camp_svc.campaign_path(cid, campaign_id)
        op.create.asset = rn
        op.create.field_type = client.enums.AssetFieldTypeEnum[field_type]
        req.operations.append(op)
    req.validate_only = DRY_RUN
    resp = ca_svc.mutate_campaign_assets(request=req)
    return [r.resource_name for r in resp.results]


@mcp.tool()
def get_campaign_id_by_name(name_contains: str, customer_id: str = "") -> str:
    """Sucht ENABLED-Kampagnen, deren Name den Text enthaelt, und gibt id+name als JSON zurueck.
    Praktisch, um die campaign_id fuer die Asset-Tools zu finden.
    """
    client = get_client()
    cid = customer_id or DEFAULT_CUSTOMER_ID
    ga = client.get_service("GoogleAdsService")
    q = "SELECT campaign.id, campaign.name, campaign.status FROM campaign WHERE campaign.status = 'ENABLED'"
    hits = []
    for b in ga.search_stream(customer_id=cid, query=q):
        for r in b.results:
            if name_contains.lower() in r.campaign.name.lower():
                hits.append({"id": str(r.campaign.id), "name": r.campaign.name})
    return json.dumps({"matches": hits}, ensure_ascii=False)


@mcp.tool()
