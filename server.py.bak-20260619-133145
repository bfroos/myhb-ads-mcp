@mcp.tool()
def upload_image_asset(image_url: str, name: str, customer_id: str = "") -> str:
    """Laedt ein Bild von einer URL herunter und legt es als neues Bild-Asset in der Bibliothek an.
    Gibt die neue asset_id zurueck (danach mit add_image_extension verknuepfbar).
    Fuer KI-generierte Motive: Bild zuerst extern erzeugen/hosten, dann hier per URL hochladen.
    PNG/JPG, empfohlen 1200x1200 (1:1) oder 1200x628 (1.91:1), max ~5MB.
    """
    import urllib.request
    client = get_client()
    cid = customer_id or DEFAULT_CUSTOMER_ID
    with urllib.request.urlopen(image_url, timeout=30) as resp:
        data = resp.read()
    svc = client.get_service("AssetService")
    op = client.get_type("AssetOperation")
    op.create.name = name
    op.create.type_ = client.enums.AssetTypeEnum["IMAGE"]
    op.create.image_asset.data = data
    req = client.get_type("MutateAssetsRequest")
    req.customer_id = cid
    req.operations.append(op)
    req.validate_only = DRY_RUN
    r = svc.mutate_assets(request=req)
    rn = r.results[0].resource_name if r.results else None
    aid = rn.split("/")[-1] if rn else None
    return json.dumps({"dry_run": DRY_RUN, "asset_id": aid, "resource_name": rn, "bytes": len(data)})


# --- PMax Asset-Gruppen-Ebene-Tools ---
# Bei PMax sitzen Logo/BusinessName/Headlines/Bilder auf der ASSET-GROUP (AssetGroupAsset).
# Sitelinks/Callouts/Snippets/Call/Price laufen auf Kampagnen-Ebene (CampaignAsset, s.o.) und
# gelten dort automatisch fuer die ganze PMax-Kampagne.

def _agasset_link(client, cid, asset_group_id, asset_rn, field_type):
    """Bindet ein vorhandenes Asset (resource_name) an eine Asset-Gruppe (respektiert DRY_RUN)."""
    ag_svc = client.get_service("AssetGroupService")
    svc = client.get_service("AssetGroupAssetService")
    op = client.get_type("AssetGroupAssetOperation")
    op.create.asset_group = ag_svc.asset_group_path(cid, asset_group_id)
    op.create.asset = asset_rn
    op.create.field_type = client.enums.AssetFieldTypeEnum[field_type]
    req = client.get_type("MutateAssetGroupAssetsRequest")
    req.customer_id = cid
    req.operations.append(op)
    req.validate_only = DRY_RUN
    resp = svc.mutate_asset_group_assets(request=req)
    return resp.results[0].resource_name if resp.results else None


@mcp.tool()
def link_image_to_asset_group(asset_group_id: str, asset_id: str, field_type: str = "MARKETING_IMAGE", customer_id: str = "") -> str:
    """Bindet ein VORHANDENES Bild-/Logo-Asset (per ID aus list_image_assets) an eine PMax-Asset-Gruppe.
    field_type fuer PMax: LOGO (1:1, >=128px), LANDSCAPE_LOGO (4:1), MARKETING_IMAGE (1.91:1, >=600x314),
    SQUARE_MARKETING_IMAGE (1:1, >=300x300), PORTRAIT_MARKETING_IMAGE (4:5, >=480x600).
    """
    client = get_client()
    cid = customer_id or DEFAULT_CUSTOMER_ID
    asset_svc = client.get_service("AssetService")
    rn = asset_svc.asset_path(cid, asset_id)
    out = _agasset_link(client, cid, asset_group_id, rn, field_type)
    return json.dumps({"dry_run": DRY_RUN, "linked": out, "field_type": field_type, "asset_group_id": asset_group_id})


@mcp.tool()
def add_text_to_asset_group(asset_group_id: str, texts: list[str], field_type: str = "HEADLINE", customer_id: str = "") -> str:
    """Legt Text-Assets an und bindet sie an eine PMax-Asset-Gruppe.
    field_type: HEADLINE (<=30 Z.), LONG_HEADLINE (<=90 Z.), DESCRIPTION (<=90 Z.),
    LONG_DESCRIPTION (<=90 Z.), BUSINESS_NAME (<=25 Z.).
    Wichtig: KEIN 'Botox' in Texten (Markenname -> Disapproval); 'Muskelrelaxans'/'Faltenbehandlung' nutzen.
    """
    client = get_client()
    cid = customer_id or DEFAULT_CUSTOMER_ID
    # 1) Assets anlegen
    asset_svc = client.get_service("AssetService")
    ops = []
    for t in texts:
        op = client.get_type("AssetOperation")
        op.create.text_asset.text = t
        ops.append(op)
    req = client.get_type("MutateAssetsRequest")
    req.customer_id = cid
    req.operations.extend(ops)
    req.validate_only = DRY_RUN
    resp = asset_svc.mutate_assets(request=req)
    rns = [r.resource_name for r in resp.results]
    # 2) an Asset-Gruppe binden
    linked = []
    for rn in rns:
        linked.append(_agasset_link(client, cid, asset_group_id, rn, field_type))
    return json.dumps({"dry_run": DRY_RUN, "created": len(rns), "linked": len([x for x in linked if x]), "field_type": field_type, "asset_group_id": asset_group_id})


