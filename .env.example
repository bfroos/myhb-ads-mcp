# Google Ads API Credentials (see https://developers.google.com/google-ads/api/docs/client-libs/python/quickstart)
GOOGLE_ADS_DEVELOPER_TOKEN=<your_developer_token>
GOOGLE_ADS_CLIENT_ID=<your_client_id>
GOOGLE_ADS_CLIENT_SECRET=<your_client_secret>
GOOGLE_ADS_REFRESH_TOKEN=<your_refresh_token>

# Optional: For multi-account setup
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Default customer ID (company account)
GOOGLE_ADS_CUSTOMER_ID=7904003244

# MCP Server Security
CONNECTOR_TOKEN=<secure_bearer_token>

# Test Mode (set to 1 for validate_only, 0 for live)
DRY_RUN=0

# Server Port
PORT=8090
